# ==============================================
# EXPENSE TRACKER API - ENVIRONMENT VARIABLES
# ==============================================

# Database Configuration
# -----------------------
# For development (SQLite) - default
DATABASE_URL=sqlite:///./expenses.db

# For production (PostgreSQL) - uncomment and configure:
# DATABASE_URL=postgresql://username:password@localhost:5432/expenses_db

# JWT Authentication
# ------------------
# IMPORTANT: Change SECRET_KEY in production!
# Generate a secure key: openssl rand -hex 32
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS Origins
# ------------
# Comma-separated list of allowed origins
# For production, add your Vercel frontend URL: https://your-app.vercel.app
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173,http://127.0.0.1:3000

# Google OAuth Configuration
# ---------------------------
# IMPORTANT: Follow GOOGLE-OAUTH-SETUP-GUIDE.md for complete setup instructions
# Get credentials from: https://console.cloud.google.com/apis/credentials
# 
# Steps:
# 1. Create OAuth 2.0 Client ID in Google Cloud Console
# 2. Add authorized JavaScript origins: http://localhost:5173, http://localhost:8000
# 3. Add authorized redirect URI: http://localhost:8000/auth/google/callback
# 4. Copy Client ID and Client Secret here
#
# Client ID format: 123456789-xxxxxxxx.apps.googleusercontent.com
# Client Secret format: GOCSPX-xxxxxxxxxxxxx
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback
FRONTEND_URL=http://localhost:5173
