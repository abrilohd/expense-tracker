# ==============================================
# LANDING PAGE - ENVIRONMENT VARIABLES
# ==============================================

# Frontend App URL (React)
# The landing page will redirect CTAs to this URL
# Development: http://localhost:5173
# Production: https://your-app.vercel.app
ENV_APP_URL=http://localhost:5173

# Backend API URL (optional - for future use)
# Development: http://localhost:8000
# Production: https://your-railway-backend.up.railway.app
ENV_API_URL=http://localhost:8000

# ==============================================
# PRODUCTION EXAMPLE (for Vercel deployment)
# ==============================================
# ENV_APP_URL=https://expense-tracker-app.vercel.app
# ENV_API_URL=https://expense-tracker-api.up.railway.app

# ==============================================
# USAGE NOTES
# ==============================================
# These environment variables can be set in Vercel dashboard
# or injected via <script> tag before config.js loads:
#
# <script>
#   window.ENV_APP_URL = 'https://your-app.vercel.app';
#   window.ENV_API_URL = 'https://your-api.railway.app';
# </script>
# <script src="config.js"></script>
