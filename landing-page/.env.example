# Landing Page Environment Configuration
# ========================================
# 
# NOTE: This is for reference only. The landing page uses
# automatic environment detection in config.js
#
# Local Development:
# - Automatically uses http://localhost:5173
#
# Production:
# - Automatically uses https://app.yourapp.com
#
# To customize for production, edit config.js directly
# or set these values in your hosting platform

# Production App URL (React Frontend)
APP_URL=https://app.yourapp.com

# Production API URL (Backend)
API_URL=https://api.yourapp.com

# Landing Page URL
LANDING_URL=https://yourapp.com
